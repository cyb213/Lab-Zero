# secrets — never commit
.env
*.env

# recall index + memory artifacts (rebuilt locally, can be large)
memory/*.db
memory/*.jsonl
memory/*-state.json

# python
__pycache__/
*.pyc
.venv*/

# build artifacts — never commit (engine uses pip sqlite-vec, no vendored binary)
*.so
*.whl
.tmp*/
dist/

# harness wiring generated locally by `bootstrap.sh --harness …` (never committed):
#  - .codex/         : Codex recall hooks + config (derived from the canonical core)
#  - AGENTS.override.md : Codex identity shadow (your resolved IDENTITY.md — personal)
#  - .lab/           : active-harness state
.codex/
AGENTS.override.md
.lab/

# contribute.sh output — a leak-audited patch, but still your local artifact (not
# meant to be committed into your Lab). Audited-clean by construction; this is tidiness.
lab-zero-contribution.patch

# os
.DS_Store

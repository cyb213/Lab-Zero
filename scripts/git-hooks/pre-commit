#!/usr/bin/env bash
# Drift gate — two independent checks; git runs exactly one pre-commit, so both live
# here. The commit is aborted if EITHER check fails.
#
#   1. Tracking-drift. When a commit ADDS a new Sessions/YYYY-MM-DD_NNN_*.md, every
#      configured tracking file must contain the literal "session N" (no zero-padding).
#      Otherwise abort. Mid-session commits that add no session note aren't gated;
#      modifications to existing notes aren't gated — only ADDs. Plus: a newly-added
#      note must not reuse an NNN already used by a different committed note
#      (parallel-session number-collision guard).
#
#   2. Skills-sync. A workspace ships its ceremonies in two dirs that must stay
#      identical — canonical .agents/skills/<X> and committed clone-and-go .claude/
#      skills/<X> copies. When a commit touches either dir, scripts/check-skills-sync.sh
#      must pass. Gated on a LOCAL .agents/skills/ existing (the canonical source at this
#      root) OR the commit DELETING one — so it enforces in stamped projects (which ship
#      both dirs) and catches the `rm -rf .agents/skills` silencing trick, while staying
#      idle in the factory root (which keeps only .claude/skills/, guarded by
#      check-src-sync.sh, and has no local .agents/skills/ canonical).
#
# Tracking files come from recall.config.json `tracking_files` (default the four-file
# convention). Bypass either gate with `git commit --no-verify` only for a real reason
# (emergency fix, backfill, tooling).

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
fails=0

# ── 1. tracking-drift gate ────────────────────────────────────────────────────
new_sessions=$(
  git diff --cached --name-only --diff-filter=A 2>/dev/null \
    | grep -E '^Sessions/[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{3}_.*\.md$' || true
)
if [ -n "$new_sessions" ]; then
  # Tracking-file list from config (via recall_lib --env); fall back to the
  # four-file convention if the engine isn't present.
  VENV_PY="$repo_root/.venv/bin/python"
  [ -x "$VENV_PY" ] || VENV_PY="python3"
  RECALL_TRACKING_FILES=""
  if [ -f "$repo_root/scripts/recall_lib.py" ]; then
    eval "$("$VENV_PY" "$repo_root/scripts/recall_lib.py" --env 2>/dev/null | grep '^export RECALL_TRACKING_FILES=')" || true
  fi
  [ -z "${RECALL_TRACKING_FILES:-}" ] && RECALL_TRACKING_FILES="Log/STATUS.md Log/TASKS.md Log/PLAN.md Log/DECISIONS.md"
  read -r -a tracking <<< "$RECALL_TRACKING_FILES"

  while IFS= read -r note; do
    base=$(basename "$note")
    num_padded=$(echo "$base" | sed -nE 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}_([0-9]{3})_.*/\1/p')
    num=$(echo "$num_padded" | sed 's/^0*//')
    [ -z "$num" ] && num=0
    marker="session $num"

    # Parallel-session collision guard: one session = one note file.
    if [ "$num" -gt 0 ]; then
      clash=$(
        git ls-tree -r --name-only HEAD -- Sessions/ 2>/dev/null \
          | grep -E "^Sessions/[0-9]{4}-[0-9]{2}-[0-9]{2}_0*${num}_.*\.md$" \
          | grep -vF "$note" || true
      )
      if [ -n "$clash" ]; then
        echo "collision: session $num already used by committed note: $clash" >&2
        echo "  (adding $note) — parallel-session number clash; pick the next free number." >&2
        fails=$((fails + 1))
      fi
    fi

    for f in "${tracking[@]}"; do
      if ! grep -qF "$marker" "$repo_root/$f" 2>/dev/null; then
        echo "drift: $f missing '$marker' (from new session note $note)" >&2
        fails=$((fails + 1))
      fi
    done
  done <<< "$new_sessions"
fi

# ── 2. skills-sync gate ───────────────────────────────────────────────────────
# Fire only when this commit touches a ceremony dir...
staged_skills=$(
  git diff --cached --name-only 2>/dev/null \
    | grep -E '^\.(agents|claude)/skills/' || true
)
# ...AND this root has a local canonical .agents/skills/ (stamped project / consumer Lab)
# OR the commit is DELETING one (the silencing trick). The factory root keeps only
# .claude/skills/ (no .agents/skills/, never deletes one) → gate stays idle here.
agents_deletion=$(
  git diff --cached --name-only --diff-filter=D 2>/dev/null \
    | grep -E '^\.agents/skills/' || true
)
if [ -n "$staged_skills" ] \
   && { [ -d "$repo_root/.agents/skills" ] || [ -n "$agents_deletion" ]; } \
   && [ -f "$repo_root/scripts/check-skills-sync.sh" ]; then
  if ! bash "$repo_root/scripts/check-skills-sync.sh" "$repo_root" >&2; then
    fails=$((fails + 1))
  fi
fi

# ── verdict ───────────────────────────────────────────────────────────────────
if [ "$fails" -gt 0 ]; then
  {
    echo ""
    echo "Pre-commit drift gate failed ($fails issue(s) above)."
    echo "Fix the listed file(s) and re-stage."
    echo "Bypass with --no-verify ONLY if you have a real reason."
  } >&2
  exit 1
fi
exit 0

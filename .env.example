# .env.example — copy to .env and fill in only what you use.
#
# IMPORTANT: recall (semantic search) needs NO API keys — it embeds locally with
# fastembed. These keys are entirely OPTIONAL and only matter if you want the
# agent to use these providers for your own tasks (cheap LLM calls, web search,
# hosting, etc.). Leave any you don't use blank or delete the line.
#
# .env is gitignored — your real keys never get committed.

# -- LLM providers (for non-Claude tasks: cheap/fast generation, summarization) -
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -- Web search / scraping (for research workflows) ----------------------------
EXA_API_KEY=
FIRECRAWL_API_KEY=
BRAVE_API_KEY=

# -- Vector DB (optional; recall itself uses local sqlite-vec, not this) --------
PINECONE_API_KEY=

# -- Hosting / infra (only if you deploy from your projects) -------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# secrets — never commit
.env
*.env
# pre-commit redaction screen: your project-local owner-identifier list (your private
# codenames, one per line). Personal data — full-coverage source for the OWNER class.
# Never commit. Absent => the screen falls back to git-config-derived identifiers.
.redaction-identifiers

# recall index + memory artifacts (rebuilt locally)
memory/*.db
memory/*.jsonl
memory/*-state.json
# promoted correction-learnings (personal; written by /review-corrections — never commit)
memory/LEARNED.md

# python / venv
__pycache__/
*.pyc
.venv*/

# build artifacts
*.so
*.whl
.tmp*/

# harness wiring generated locally by `bootstrap.sh --harness …` (never committed):
#  - .codex/         : Codex recall hooks + config (derived from the canonical core)
#  - AGENTS.override.md : Codex identity shadow (your resolved IDENTITY.md — personal)
#  - .lab/           : active-harness state
.codex/
AGENTS.override.md
.lab/

# os
.DS_Store
